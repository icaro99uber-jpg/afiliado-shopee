generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductLead {
  copies            GeneratedCopy[]
  id                String   @id @default(cuid())
  providerProductId String   @unique
  nome              String
  categoria         String
  preco             Float
  desconto          Float
  nota              Float
  vendidos          Int
  comissao          Float
  loja              String
  urlImagem         String
  url               String?
  title             String
  score             Int?
  scoreUpdatedAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}


model GeneratedCopy {
  id        String      @id @default(cuid())
  productId String
  product   ProductLead @relation(fields: [productId], references: [id], onDelete: Cascade)
  titulo    String
  mensagem  String
  cta       String
  hashtags  String
  createdAt DateTime    @default(now())

  @@index([productId])
}
