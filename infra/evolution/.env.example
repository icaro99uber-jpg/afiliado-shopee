# Compose local
EVOLUTION_HOST_PORT=8080

# PostgreSQL local da Evolution API
POSTGRES_DB=evolution
POSTGRES_USER=evolution
POSTGRES_PASSWORD=replace-with-generated-postgres-password

# Servidor e autenticacao suportados pela Evolution API 2.3.6
SERVER_URL=http://localhost:8080
SERVER_PORT=8080
AUTHENTICATION_API_KEY=replace-with-generated-api-key
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

# Banco e persistencia minima
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:replace-with-generated-postgres-password@evolution-postgres:5432/evolution?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=shopee_evolution_local
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=false
DATABASE_SAVE_MESSAGE_UPDATE=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_DATA_CHATS=false
DATABASE_SAVE_DATA_LABELS=false
DATABASE_SAVE_DATA_HISTORIC=false
DATABASE_SAVE_IS_ON_WHATSAPP=false
DATABASE_DELETE_MESSAGE=false

# Cache interno
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/6
CACHE_REDIS_PREFIX_KEY=shopee-evolution-local
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# QR Code: nenhum QR e gerado sem criacao/conexao manual de instancia
QRCODE_LIMIT=1

# Integracoes nao utilizadas
TELEMETRY_ENABLED=false
PROMETHEUS_METRICS=false
RABBITMQ_ENABLED=false
SQS_ENABLED=false
WEBSOCKET_ENABLED=false
PUSHER_ENABLED=false
KAFKA_ENABLED=false
NATS_ENABLED=false
WEBHOOK_GLOBAL_ENABLED=false
TYPEBOT_ENABLED=false
CHATWOOT_ENABLED=false
OPENAI_ENABLED=false
DIFY_ENABLED=false
N8N_ENABLED=false
EVOAI_ENABLED=false
FLOWISE_ENABLED=false
S3_ENABLED=false
